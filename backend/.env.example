# 数据库配置（PostgreSQL）
POSTGRES_HOST="localhost"
POSTGRES_PORT=5432
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="123456"
POSTGRES_DATABASE="legal_consultation"

# 默认模型提供商
DEFAULT_MODEL_PROVIDER="siliconflow"  # siliconflow, ollama
# 嵌入模型提供商
EMBEDDING_MODEL_PROVIDER="siliconflow"  # siliconflow, ollama

# AI 模型配置
# 硅基流动模型配置
SILICONFLOW_API_KEY="your-api-key"
SILICONFLOW_BASE_URL="https://api.siliconflow.cn/v1"
SILICONFLOW_MODEL="deepseek-ai/DeepSeek-V3"
SILICONFLOW_EMBEDDING_MODEL="Qwen/Qwen3-Embedding-8B"

# Ollama 本地模型配置
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="deepseek-r1:1.5b"
OLLAMA_EMBEDDING_MODEL="qwen3-embedding:0.6b"

# 应用配置
DEBUG=true
HOST="0.0.0.0"
PORT=8000
LOG_LEVEL="INFO"

# 聊天配置
MAX_CHAT_HISTORY=50
CHAT_TIMEOUT=30
AI_SIMPLE_MODE=true  # true=简化模式，false=复杂模式(以下可详细更改)

# AI服务配置
AI_USE_KNOWLEDGE_BASE=true  # 是否使用知识库增强
AI_DEFAULT_TEMPERATURE=0.7  # 默认温度参数
AI_DEFAULT_MAX_TOKENS=2000  # 默认最大token数
AI_LEGAL_SUGGESTION_TEMPERATURE=0.3  # 法律建议生成的温度

# 知识库检索配置
KB_SIMPLE_RESULTS=2  # 简化模式检索结果数
KB_FULL_RESULTS=3  # 完整模式检索结果数
KB_LEGAL_SUGGESTION_RESULTS=3  # 法律建议生成检索结果数
KB_SIMPLE_TIMEOUT=5.0  # 简化模式检索超时（秒）
KB_LEGAL_SUGGESTION_TIMEOUT=10.0  # 法律建议生成检索超时（秒）

# HTTP客户端配置
HTTP_CLIENT_TIMEOUT=60.0  # HTTP客户端超时（秒）
HTTP_MAX_KEEPALIVE_CONNECTIONS=5  # 最大保持连接数
HTTP_MAX_CONNECTIONS=10  # 最大连接数

# 模型请求超时配置
SILICONFLOW_REQUEST_TIMEOUT=60.0  # SiliconFlow请求超时（秒）- 从30增加到60
SILICONFLOW_RETRY_TIMEOUT=90.0  # SiliconFlow重试超时（秒）- 从45增加到90
OLLAMA_REQUEST_TIMEOUT=30.0  # Ollama请求超时（秒）- 从20增加到30

# 对话历史配置
AI_MAX_HISTORY_MESSAGES=5  # 默认最大历史消息数
AI_SIMPLE_MAX_HISTORY=3  # 简化模式最大对话轮数