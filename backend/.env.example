# 数据库配置（PostgreSQL）
POSTGRES_HOST="localhost"
POSTGRES_PORT=5432
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="123456"
POSTGRES_DATABASE="legal_consultation"

# 默认模型提供商
DEFAULT_MODEL_PROVIDER="siliconflow"  # siliconflow, ollama
# 嵌入模型提供商
EMBEDDING_MODEL_PROVIDER="siliconflow"  # siliconflow, ollama

# AI 模型配置
# 硅基流动模型配置
SILICONFLOW_API_KEY="your-API-keys"
SILICONFLOW_BASE_URL="https://api.siliconflow.cn/v1"
SILICONFLOW_MODEL="deepseek-ai/DeepSeek-V3"
SILICONFLOW_EMBEDDING_MODEL="Qwen/Qwen3-Embedding-8B"

# Ollama 本地模型配置
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="deepseek-r1:1.5b"
OLLAMA_EMBEDDING_MODEL="qwen3-embedding:0.6b"

# 应用配置
DEBUG=true
HOST="0.0.0.0"
PORT=8000
LOG_LEVEL="INFO"

# 聊天配置
MAX_CHAT_HISTORY=50
CHAT_TIMEOUT=30
